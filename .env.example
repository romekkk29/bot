# https://console.groq.com/keys
GROQ_API_KEY=

# Modelo (opcional). Ver modelos activos en la documentación de Groq.
GROQ_MODEL=llama-3.3-70b-versatile

# --- WhatsApp/Kapso API ---
WHATSAPP_API_KEY=
WHATSAPP_API_URL=https://api.kapso.io

# Opcional: datos reales desde Supabase (Project Settings → API).
# Cada deploy del bot suele tener su propio proyecto Supabase → URL/key de ese ERP.
# Recomendado service_role solo en servidor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Ventas (get_sales_summary) ---
# Modo orders: suma importes de cabeceras en el rango (recomendado si total_amount es la verdad).
# ERP_SUPABASE_SALES_SOURCE=orders
# ERP_SUPABASE_SALES_TABLE=sales_orders
# ERP_SUPABASE_SALES_DATE_COL=order_date
# ERP_SUPABASE_SALES_AMOUNT_COL=total_amount
#
# Modo items: suma line_total por líneas de pedido (primero pedidos en el rango de fechas, luego ítems).
# Requiere que sales_order_items tenga la FK sales_order_id → sales_orders.id (nombre configurable).
# ERP_SUPABASE_SALES_SOURCE=items
# ERP_SUPABASE_SALES_ITEMS_TABLE=sales_order_items
# ERP_SUPABASE_SALES_ITEMS_AMOUNT_COL=line_total
# ERP_SUPABASE_SALES_ITEMS_FK_COL=sales_order_id
# ERP_SUPABASE_SALES_ORDERS_TABLE=sales_orders
# ERP_SUPABASE_SALES_ORDER_DATE_COL=order_date
# ERP_SUPABASE_SALES_ORDER_ID_COL=id
# Para top productos vendidos:
# ERP_SUPABASE_SALES_ITEMS_PRODUCT_ID_COL=product_id
# ERP_SUPABASE_SALES_ITEMS_QTY_COL=quantity
# Tamaño del lote de IDs de pedido para cada query de ítems (default 80, máx 200):
# ERP_SUPABASE_SALES_ITEMS_ORDER_ID_CHUNK=80

# --- Listado de órdenes de venta (list_sales_orders) ---
# Tabla: por defecto usa ORDERS_LIST_TABLE, si no SALES_ORDERS_TABLE, si no SALES_TABLE, si no sales_orders.
# ERP_SUPABASE_ORDERS_LIST_TABLE=sales_orders
# Columna de fecha para filtrar (default order_date o la de ventas):
# ERP_SUPABASE_ORDERS_LIST_DATE_COL=order_date
# Columnas en SELECT (coma):
# ERP_SUPABASE_ORDERS_LIST_SELECT=id,order_number,order_date,total_amount,status,currency
# Enriquecer órdenes con cliente desde customer_id -> customers (default true):
# ERP_SUPABASE_ORDERS_INCLUDE_CUSTOMER=true
# ERP_SUPABASE_ORDERS_CUSTOMER_ID_COL=customer_id
# Si el usuario no dice fechas: ventana de tantos días hacia atrás desde hoy (default 90):
# ERP_SUPABASE_ORDERS_LIST_DEFAULT_DAYS=90

# --- Compras / órdenes de compra (get_purchase_summary, list_purchase_orders, count_purchase_orders_by_status) ---
# ERP_SUPABASE_PURCHASE_ORDERS_TABLE=purchase_orders
# Alias corto: ERP_SUPABASE_PO_TABLE=purchase_orders
# ERP_SUPABASE_PO_DATE_COL=order_date
# ERP_SUPABASE_PO_AMOUNT_COL=total_amount
# ERP_SUPABASE_PO_STATUS_COL=status
# Columnas del listado (coma):
# ERP_SUPABASE_PO_LIST_SELECT=id,number,supplier_id,branch_id,order_date,expected_date,total_amount,tax_amount,subtotal,status,order_type,notes
# Enriquecer con proveedor (supplier_id -> suppliers): default true
# ERP_SUPABASE_PO_INCLUDE_SUPPLIER=true
# ERP_SUPABASE_PO_SUPPLIER_ID_COL=supplier_id
# Ventana por defecto si el usuario no da fechas (días hacia atrás desde hoy):
# ERP_SUPABASE_PO_LIST_DEFAULT_DAYS=90

# --- Líneas de orden de compra (list_purchase_order_items) ---
# ERP_SUPABASE_PURCHASE_ORDER_ITEMS_TABLE=purchase_order_items
# ERP_SUPABASE_PO_ITEMS_FK_COL=purchase_order_id
# ERP_SUPABASE_PO_ITEMS_SELECT=id,purchase_order_id,product_id,quantity,unit_price,total_price,received_quantity,unit,notes,tax_rate,tax_amount,received_weight,discount_percentage_2

# Nombres de tablas si no usás los defaults erp_sales / erp_products
# ERP_SUPABASE_SALES_TABLE=erp_sales
# ERP_SUPABASE_PRODUCTS_TABLE=erp_products

# Mapeo si tu tabla es public.products (SKU, nombre comercial, precio venta, UUID interno):
# ERP_SUPABASE_PRODUCTS_TABLE=products
# ERP_SUPABASE_PRODUCT_COL_CODE=sku
# ERP_SUPABASE_PRODUCT_COL_NAME=name
# ERP_SUPABASE_PRODUCT_COL_PRICE=sale_price
# ERP_SUPABASE_PRODUCT_COL_UUID=id
# Opcionales para búsqueda por barcode/código ARCA:
# ERP_SUPABASE_PRODUCT_COL_BARCODE=barcode
# ERP_SUPABASE_PRODUCT_COL_ARCA_CODE=arca_product_code

# --- Stock por depósito (get_product_available_stock, list_products_below_min_stock) ---
# ERP_SUPABASE_WAREHOUSE_STOCK_TABLE=warehouse_stock
# ERP_SUPABASE_WAREHOUSE_STOCK_PRODUCT_ID_COL=product_id
# ERP_SUPABASE_WAREHOUSE_STOCK_WAREHOUSE_ID_COL=warehouse_id
# ERP_SUPABASE_WAREHOUSE_STOCK_STOCK_COL=stock
# ERP_SUPABASE_WAREHOUSE_STOCK_RESERVED_COL=reserved_stock
# ERP_SUPABASE_WAREHOUSE_STOCK_MIN_COL=min_stock
# ERP_SUPABASE_WAREHOUSE_STOCK_PROJECTED_COL=stock_projected

# --- Cardex / movimientos (list_recent_product_movements) ---
# ERP_SUPABASE_CARDEX_TABLE=cardex_report
# ERP_SUPABASE_CARDEX_DATE_COL=fecha_hora
# ERP_SUPABASE_CARDEX_PRODUCT_ID_COL=product_id
# ERP_SUPABASE_CARDEX_MOVEMENT_TYPE_COL=tipo_movimiento
# ERP_SUPABASE_CARDEX_QTY_IN_COL=cantidad_entrada
# ERP_SUPABASE_CARDEX_QTY_OUT_COL=cantidad_salida
# ERP_SUPABASE_CARDEX_SKU_COL=sku
# ERP_SUPABASE_CARDEX_PRODUCT_DESC_COL=descripcion_producto

# --- Proveedores (search_suppliers) — defaults = tabla public.suppliers estándar ---
# ERP_SUPABASE_SUPPLIERS_TABLE=suppliers
# ERP_SUPABASE_SUPPLIER_COL_ID=id
# ERP_SUPABASE_SUPPLIER_COL_BUSINESS_NAME=business_name
# ERP_SUPABASE_SUPPLIER_COL_TAX_ID=tax_id
# ERP_SUPABASE_SUPPLIER_COL_CONTACT=contact_name
# ERP_SUPABASE_SUPPLIER_COL_EMAIL=email
# ERP_SUPABASE_SUPPLIER_COL_PHONE=phone
# ERP_SUPABASE_SUPPLIER_COL_ACTIVE=is_active
# Solo proveedores activos:
# ERP_SUPABASE_SUPPLIERS_ONLY_ACTIVE=true
# Columnas adicionales en SELECT y en cada resultado (coma, sin espacios raros):
# ERP_SUPABASE_SUPPLIER_EXTRA_COLS=payment_terms,city,address

# --- Clientes (search_customers) — defaults = tabla public.customers estándar ---
# ERP_SUPABASE_CUSTOMERS_TABLE=customers
# ERP_SUPABASE_CUSTOMER_COL_ID=id
# ERP_SUPABASE_CUSTOMER_COL_BUSINESS_NAME=business_name
# ERP_SUPABASE_CUSTOMER_COL_TAX_ID=tax_id
# ERP_SUPABASE_CUSTOMER_COL_CONTACT=contact_name
# ERP_SUPABASE_CUSTOMER_COL_INTERNAL_CODE=internal_code
# ERP_SUPABASE_CUSTOMER_COL_EMAIL=email
# ERP_SUPABASE_CUSTOMER_COL_PHONE=phone
# ERP_SUPABASE_CUSTOMER_COL_ACTIVE=is_active
# Solo clientes activos:
# ERP_SUPABASE_CUSTOMERS_ONLY_ACTIVE=true
# Columnas adicionales:
# ERP_SUPABASE_CUSTOMER_EXTRA_COLS=city,address,payment_terms
